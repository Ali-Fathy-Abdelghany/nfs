flowchart TD
    Start((Begin)) --> Landing[Landing Page]
    
    Landing --> Auth{New User?}
    Auth -- Yes --> Register[Sign Up Page]
    Auth -- No --> Login[Login Page]

    subgraph Registration_Process
    Register --> Data[Enter Details]
    Data --> Validate{Valid Data?}
    Validate -- No --> Data
    Validate -- Yes --> Consent[Mandatory Consent Check]
    Consent --> Create[Account Created]
    end
    
    Create --> Dashboard
    Login --> Dashboard[User Dashboard]

    Dashboard --> Options{Select Action}
    
    Options -- AI Guidance --> AIChat[AI Chatbot interaction]
    Options -- Take Assessment --> Scores[Answer Questions & Calculate Scores]
    
    Scores --> Emergency{Red Flag \n Score >= 50?}
    Emergency -- Yes --> Crisis[Show Emergency Hotline & Specialist]
    Emergency -- No --> Reco[Show Personalized Recommendations]

    Options -- Book Session --> Search[Filter & Search Therapists]
    Search --> Slot[Select Date & Time Slot]
    Slot --> Available{Is Slot \n Available?}
    Available -- No --> Slot
    Available -- Yes --> PayType[Select Type: Online / Offline]
    
    PayType --> Payment[Payment Process]
    Payment --> Confirm[Booking Confirmed]

    Crisis --> End((End))
    Confirm --> Dashboard
    Reco --> Search
    AIChat --> Dashboard