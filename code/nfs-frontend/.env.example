# Frontend env — copy values into .env / .env.local (do not commit secrets).

VITE_API_BASE_URL=http://localhost:5148

# Google Identity Services Web Client ID (public; same value as OAuth__Google__ClientId on API).
# Authorized JavaScript origin for local: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
