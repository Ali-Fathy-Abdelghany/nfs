# NFS.API environment template — copy to .env and fill in real values.
# Never commit .env with real secrets.

# --- Paymob (Egypt Accept) ---
PAYMOB_SECRET_KEY=sk_test_xxxxxxxx
PAYMOB_PUBLIC_KEY=pk_test_xxxxxxxx
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_HMAC=your_paymob_hmac_secret
PAYMOB_INTEGRATION_ID=1234567
PAYMOB_BASE_URL=https://accept.paymob.com
# Public base URL of this API (use ngrok/cloudflare tunnel in local/dev so Paymob can POST webhooks).
# Local http port must match launchSettings (default http://localhost:5148). Browser return can use localhost; TRANSACTION webhook cannot.
PAYMOB_CALLBACK_BASE_URL=https://your-public-api-host.example
# Frontend origin for post-payment redirect UX
FRONTEND_BASE_URL=http://localhost:5173

# --- SQL Server (quote if password has ! or other special chars) ---
ConnectionStrings__DefaultConnection="Server=YOUR_SERVER;Database=NfsDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"

# --- MongoDB (chat) — always quote if password contains # (otherwise treated as a comment) ---
MongoSettings__ConnectionString="mongodb+srv://USER:PASSWORD@cluster.example.net/?appName=Cluster0"
MongoSettings__Database=ChatDb

# --- JWT ---
JwtSettings__Secret=REPLACE_WITH_LONG_RANDOM_SECRET
JwtSettings__Issuer=NafsApp
JwtSettings__Audience=NafsAppUsers
JwtSettings__ExpiryMinutes=60
JwtSettings__RefreshTokenExpiryDays=7

# --- Email (SMTP) — Gmail App Password / SendGrid SMTP / Mailtrap / etc. ---
# Leave blank to soft-fail (app runs; accept/reject still update DB; emails are logged as skipped).
Email__Enabled=true
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUser=your@gmail.com
Email__SmtpPass=your_app_password
Email__FromAddress=your@gmail.com
Email__FromName=Nafs
# Reminder job: emails Confirmed appointments starting within N hours; polls every M minutes.
Email__ReminderHoursBefore=24
Email__ReminderPollMinutes=15

# --- Google OAuth (ID token audience verification) ---
# Same Web client ID as VITE_GOOGLE_CLIENT_ID on the frontend.
OAuth__Google__ClientId=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# --- LiveKit video meetings (never expose API secret to the frontend) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET

# --- Gemini AI ---
# Used by the nfs-ai-engine chatbot service.
Gemini__ApiKey=YOUR_GEMINI_API_KEY
Gemini__Model=gemini-2.5-flash
